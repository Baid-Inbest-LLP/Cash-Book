{
  "info": {
    "_postman_id": "c4a1e2f0-1b2c-4d3e-9f80-abcdef123456",
    "name": "💰 Cash Book API",
    "description": "Cash Book backend API collection.\n\n## Getting started\n1. Ensure the server is running (`pnpm --filter server dev`). Base URL defaults to `http://localhost:5001/api/v1` — change the `baseUrl` collection variable if your port differs.\n2. Run **Auth → Login (Superadmin)**. Its test script auto-saves `accessToken` and `refreshToken` to collection variables.\n3. All protected requests inherit Bearer auth from the collection (`{{accessToken}}`) automatically.\n4. Create requests (company, expense head, register user) auto-save the new `_id` to a variable used by the follow-up GET/PUT/DELETE requests.\n\n## Auth model\n- Public: login, refresh, forgot/reset password, health (No Auth).\n- Protected: everything else (Bearer).\n- Superadmin-only mutations are noted in each request description.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5001/api/v1", "type": "string" },
    { "key": "superadminEmail", "value": "superadmin@cashbook.com", "type": "string" },
    { "key": "superadminPassword", "value": "super123", "type": "string" },
    { "key": "accountantEmail", "value": "accountant@cashbook.com", "type": "string" },
    { "key": "accountantPassword", "value": "accountant123", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },
    { "key": "resetToken", "value": "", "type": "string" },
    { "key": "companyId", "value": "", "type": "string" },
    { "key": "locationId", "value": "", "type": "string" },
    { "key": "expenseHeadId", "value": "", "type": "string" },
    { "key": "userId", "value": "", "type": "string" },
    { "key": "entryId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "🔐 Auth",
      "description": "Authentication and account endpoints (`/auth`).",
      "item": [
        {
          "name": "🔑 Login (Superadmin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "if (res && res.data) {",
                  "  if (res.data.accessToken) pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "  if (res.data.refreshToken) pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{superadminEmail}}\",\n  \"password\": \"{{superadminPassword}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Public. Authenticates and returns `{ user, accessToken, refreshToken }`. Tokens are auto-saved to collection variables."
          },
          "response": []
        },
        {
          "name": "🔑 Login (Accountant)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "if (res && res.data) {",
                  "  if (res.data.accessToken) pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "  if (res.data.refreshToken) pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{accountantEmail}}\",\n  \"password\": \"{{accountantPassword}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Public. Log in as the accountant role to test non-superadmin permissions."
          },
          "response": []
        },
        {
          "name": "♻️ Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "if (res && res.data && res.data.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "refresh"]
            },
            "description": "Public. Exchanges a valid refresh token for a new access token (auto-saved)."
          },
          "response": []
        },
        {
          "name": "👤 Get Current User (me)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "me"]
            },
            "description": "Protected. Returns the authenticated user's profile."
          },
          "response": []
        },
        {
          "name": "🆕 Register User (Superadmin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res && res.data && res.data._id) pm.collectionVariables.set('userId', res.data._id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Accountant\",\n  \"email\": \"accountant2@cashbook.com\",\n  \"password\": \"changeme123\",\n  \"role\": \"accountant\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            },
            "description": "Superadmin only. Creates an accountant. Saves new user `_id` to `userId`."
          },
          "response": []
        },
        {
          "name": "🔒 Change Password",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"super123\",\n  \"newPassword\": \"super1234\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/change-password",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "change-password"]
            },
            "description": "Protected. Changes the authenticated user's password."
          },
          "response": []
        },
        {
          "name": "❓ Forgot Password",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "const url = res && res.data && res.data.resetUrl;",
                  "if (url) {",
                  "  const m = url.match(/token=([^&]+)/);",
                  "  if (m) pm.collectionVariables.set('resetToken', m[1]);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{superadminEmail}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/forgot-password",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "forgot-password"]
            },
            "description": "Public. In development the response includes `resetUrl`; the test script extracts its token into `resetToken`."
          },
          "response": []
        },
        {
          "name": "🔁 Reset Password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{resetToken}}\",\n  \"password\": \"newpass123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/reset-password",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "reset-password"]
            },
            "description": "Public. Resets the password using the token captured by Forgot Password."
          },
          "response": []
        },
        {
          "name": "🚪 Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "logout"]
            },
            "description": "Protected. Invalidates the stored refresh token."
          },
          "response": []
        }
      ]
    },
    {
      "name": "🏷️ Expense Heads",
      "description": "Expense head master data (`/expense-heads`). Mutations are superadmin-only.",
      "item": [
        {
          "name": "📋 List Expense Heads",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/expense-heads?activeOnly=true",
              "host": ["{{baseUrl}}"],
              "path": ["expense-heads"],
              "query": [
                {
                  "key": "activeOnly",
                  "value": "true",
                  "description": "Set to `false` to include inactive heads."
                }
              ]
            },
            "description": "Protected. Lists heads sorted by name. Active only by default; `?activeOnly=false` returns all."
          },
          "response": []
        },
        {
          "name": "➕ Create Expense Head",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('status is 201', () => pm.response.to.have.status(201));",
                  "if (res && res.data && res.data._id) pm.collectionVariables.set('expenseHeadId', res.data._id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Rent\",\n  \"isActive\": true\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/expense-heads",
              "host": ["{{baseUrl}}"],
              "path": ["expense-heads"]
            },
            "description": "Superadmin only. Creates a head. Names are unique case-insensitively (duplicate → 409). Saves `_id` to `expenseHeadId`."
          },
          "response": []
        },
        {
          "name": "✏️ Update Expense Head",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Office Rent\",\n  \"isActive\": true\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/expense-heads/{{expenseHeadId}}",
              "host": ["{{baseUrl}}"],
              "path": ["expense-heads", "{{expenseHeadId}}"]
            },
            "description": "Superadmin only. Updates name and/or isActive. 404 if missing, 409 on duplicate name."
          },
          "response": []
        },
        {
          "name": "🗑️ Delete Expense Head",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/expense-heads/{{expenseHeadId}}",
              "host": ["{{baseUrl}}"],
              "path": ["expense-heads", "{{expenseHeadId}}"]
            },
            "description": "Superadmin only. Hard-deletes a head. Blocked with 409 if referenced by any entry (deactivate instead)."
          },
          "response": []
        }
      ]
    },
    {
      "name": "📒 Entries",
      "description": "Cash book receipt/payment entries (`/entries`). All routes require auth; permanent delete is superadmin-only. Create/update/exclude/restore return only a success message (no entry payload) — the frontend refetches via React Query.",
      "item": [
        {
          "name": "📋 List Entries",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "const first = res && res.data && res.data.entries && res.data.entries[0];",
                  "if (first && first._id) pm.collectionVariables.set('entryId', first._id);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/entries?page=1&limit=50&type=&financialYear=&month=&company=&expenseHead=&isExcluded=false&fromDate=&toDate=&search=",
              "host": ["{{baseUrl}}"],
              "path": ["entries"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "50", "description": "Max 100." },
                {
                  "key": "type",
                  "value": "",
                  "description": "`receipt` or `payment`."
                },
                {
                  "key": "financialYear",
                  "value": "",
                  "description": "YYYY-YY (e.g. 2025-26). Defaults to current FY."
                },
                { "key": "month", "value": "", "description": "1–12." },
                { "key": "company", "value": "", "description": "Company ObjectId." },
                {
                  "key": "expenseHead",
                  "value": "",
                  "description": "Expense head ObjectId."
                },
                {
                  "key": "isExcluded",
                  "value": "false",
                  "description": "`true` shows the excluded/recycle-bin list."
                },
                { "key": "fromDate", "value": "", "description": "ISO date lower bound." },
                { "key": "toDate", "value": "", "description": "ISO date upper bound." },
                {
                  "key": "search",
                  "value": "",
                  "description": "Description substring (case-insensitive)."
                }
              ]
            },
            "description": "Protected. Paginated entries with a balance summary (opening/closing balance, receipt/payment totals). Test script saves the first entry's `_id` to `entryId` for the update/exclude/restore requests."
          },
          "response": []
        },
        {
          "name": "➕ Create Receipt",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"date\": \"2025-06-15\",\n  \"company\": \"{{companyId}}\",\n  \"amount\": 5000,\n  \"description\": \"Cash sale receipt\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/entries/receipt",
              "host": ["{{baseUrl}}"],
              "path": ["entries", "receipt"]
            },
            "description": "Protected. Creates a receipt entry for an active company. Returns only a success message; run List Entries to fetch it."
          },
          "response": []
        },
        {
          "name": "➕ Create Payment",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"date\": \"2025-06-16\",\n  \"company\": \"{{companyId}}\",\n  \"expenseHead\": \"{{expenseHeadId}}\",\n  \"amount\": 1200,\n  \"description\": \"Office rent payment\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/entries/payment",
              "host": ["{{baseUrl}}"],
              "path": ["entries", "payment"]
            },
            "description": "Protected. Creates a payment entry tied to an active company and expense head. Returns only a success message."
          },
          "response": []
        },
        {
          "name": "✏️ Update Entry",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 5500,\n  \"description\": \"Updated receipt amount\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/entries/{{entryId}}",
              "host": ["{{baseUrl}}"],
              "path": ["entries", "{{entryId}}"]
            },
            "description": "Protected. Updates any subset of fields (type, date, company, expenseHead, amount, description). At least one field is required. Payment entries require an expense head. Returns only a success message."
          },
          "response": []
        },
        {
          "name": "🗑️ Exclude Entry",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/entries/{{entryId}}",
              "host": ["{{baseUrl}}"],
              "path": ["entries", "{{entryId}}"]
            },
            "description": "Protected. Soft-deletes: moves the entry to the excluded/recycle-bin list (removed from balance calculations)."
          },
          "response": []
        },
        {
          "name": "♻️ Restore Entry",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/entries/{{entryId}}/restore",
              "host": ["{{baseUrl}}"],
              "path": ["entries", "{{entryId}}", "restore"]
            },
            "description": "Protected. Restores an excluded entry back into the cash book."
          },
          "response": []
        },
        {
          "name": "🗑️ Delete Entry (Permanent)",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/entries/{{entryId}}/permanent",
              "host": ["{{baseUrl}}"],
              "path": ["entries", "{{entryId}}", "permanent"]
            },
            "description": "Superadmin only. Permanently deletes an entry. Blocked with 400 unless the entry has already been excluded."
          },
          "response": []
        }
      ]
    },
    {
      "name": "📊 Reports",
      "description": "Read-only analytics (`/reports`). All require auth. Every report defaults to the current financial year when `financialYear` is omitted. Balance figures exclude excluded/recycle-bin entries.",
      "item": [
        {
          "name": "📅 Monthwise Ledger",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/reports/monthwise?financialYear=",
              "host": ["{{baseUrl}}"],
              "path": ["reports", "monthwise"],
              "query": [
                {
                  "key": "financialYear",
                  "value": "",
                  "description": "YYYY-YY (e.g. 2025-26). Defaults to current FY."
                }
