            },
            "description": "Protected. Payment totals grouped by company with `paymentAmount`, `paymentCount`, and share `percentage`. Optionally filtered by month."
          },
          "response": []
        }
      ]
    },
    {
      "name": "🏢 Companies",
      "description": "Rich company + locations module (`/companies`). Mutations are superadmin-only.",
      "item": [
        {
          "name": "📋 List Companies",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/companies?search=&isActive=&page=1&limit=50",
              "host": ["{{baseUrl}}"],
              "path": ["companies"],
              "query": [
                {
                  "key": "search",
                  "value": "",
                  "description": "Name/email/code substring (case-insensitive)."
                },
                { "key": "isActive", "value": "", "description": "`true` or `false`." },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "50", "description": "Max 100." }
              ]
            },
            "description": "Protected. Paginated list of companies with their locations."
          },
          "response": []
        },
        {
          "name": "➕ Create Company",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('status is 201', () => pm.response.to.have.status(201));",
                  "if (res && res.data && res.data._id) pm.collectionVariables.set('companyId', res.data._id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Acme Corp\",\n  \"companyCode\": \"ACME\",\n  \"email\": \"contact@acme.com\",\n  \"phone\": \"9876543210\",\n  \"taxId\": \"19ABCDE1234F1Z5\",\n  \"logo\": \"\",\n  \"isActive\": true,\n  \"locations\": [\n    {\n      \"label\": \"HQ\",\n      \"street\": \"1 Main Street\",\n      \"city\": \"Kolkata\",\n      \"state\": \"West Bengal\",\n      \"zipCode\": \"700001\",\n      \"country\": \"India\",\n      \"isDefault\": true\n    }\n  ]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/companies",
              "host": ["{{baseUrl}}"],
              "path": ["companies"]
            },
            "description": "Superadmin only. Creates a company with at least one location. Saves `_id` to `companyId`."
          },
          "response": []
        },
        {
          "name": "🔍 Get Company",
