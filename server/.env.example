NODE_ENV=development
PORT=5001
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/cashbook_db?retryWrites=true&w=majority
MONGODB_DB_NAME=cashbook_db
SUPERADMIN_EMAIL=superadmin@cashbook.com
SUPERADMIN_PASSWORD=super123
ACCOUNTANT_EMAIL=accountant@cashbook.com
ACCOUNTANT_PASSWORD=accountant123
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
# Optional: overrides the access-token lifetime. Defaults to 12h in dev, 15m in production.
# JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Cash Book System <noreply@cashbook.local>
