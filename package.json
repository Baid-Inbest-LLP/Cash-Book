{
  "name": "cash-book",
  "version": "1.0.0",
  "private": true,
  "description": "Cash Book - Internal App",
  "scripts": {
    "dev": "pnpm run --parallel dev",
    "dev:server": "pnpm --filter server dev",
    "dev:client": "pnpm --filter client dev",
    "build": "pnpm run --filter client build && pnpm run --filter server build",
    "lint": "pnpm run -r lint",
    "lint:fix": "pnpm --filter client exec eslint . --fix && pnpm --filter server exec eslint src --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "commitlint": "commitlint --from HEAD~1 --to HEAD",
    "check": "pnpm lint && pnpm format:check",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.5.3"
  },
  "lint-staged": {
    "*": "prettier --ignore-unknown --write",
    "client/**/*.{js,jsx}": "pnpm --filter client exec eslint --fix",
    "server/**/*.js": "pnpm --filter server exec eslint --fix"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
